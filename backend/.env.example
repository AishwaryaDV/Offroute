ENV=development

# Supabase session pooler (port 5432 — supports asyncpg prepared statements;
# do NOT use the transaction pooler on 6543).
# Runtime URL (async driver):
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Same database, sync driver — used only by Alembic migrations:
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

CORS_ORIGINS=http://localhost:3000
